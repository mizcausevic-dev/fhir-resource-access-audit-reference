{
  "name": "fhir-resource-access-audit-reference",
  "version": "0.1.0",
  "description": "Reference implementation of the fhir-resource-access-audit spec — Node.js end-to-end pipeline that reads from HL7 FHIR R4 (HAPI public test server), applies a HIPAA-Safe-Harbor vault contract, emits Suite-compliant hash-chained audit-stream events, and self-verifies against the spec.",
  "type": "module",
  "license": "AGPL-3.0",
  "author": "Miz Causevic",
  "homepage": "https://github.com/mizcausevic-dev/fhir-resource-access-audit-reference",
  "repository": {
    "type": "git",
    "url": "https://github.com/mizcausevic-dev/fhir-resource-access-audit-reference.git"
  },
  "bugs": {
    "url": "https://github.com/mizcausevic-dev/fhir-resource-access-audit-reference/issues"
  },
  "bin": {
    "fhir-audit-reference": "./bin/fhir-audit-reference"
  },
  "files": [
    "bin/",
    "src/",
    "fixtures/",
    "schema/",
    "examples/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build:example": "node src/cli.mjs --mode=test --output=examples/sample-output-stream.ndjson",
    "verify": "node src/cli.mjs --mode=test --output=examples/sample-output-stream.ndjson",
    "live": "node src/cli.mjs --mode=live --output=output/live-stream.ndjson",
    "test": "node --test \"tests/*.test.mjs\""
  },
  "keywords": [
    "kinetic-gain-protocol-suite",
    "fhir",
    "fhir-r4",
    "audit-stream",
    "hipaa-readiness",
    "audit-event",
    "ai-disclosure",
    "ai-governance",
    "decision-card",
    "vault-contract",
    "healthtech",
    "reference-implementation",
    "agplv3"
  ],
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
